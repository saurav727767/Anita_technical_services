{
  "name": "ats-video-editor-desktop",
  "version": "1.0.0",
  "description": "Desktop multi-track video editor suite running natively on Windows 10 and 11.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "react-start": "webpack serve --config webpack.config.js --mode development",
    "react-build": "webpack --config webpack.config.js --mode production",
    "dist": "npm run react-build && electron-builder --win nsis"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.10.0",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.2"
  },
  "build": {
    "appId": "com.ats.videoeditor",
    "productName": "ATS Video Editor",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    }
  }
}
